FROM rocker/shiny:4.5.2

RUN apt-get update && apt-get install -y \
  libuv1 \
  && rm -rf /var/lib/apt/lists/*

RUN echo 'options(repos = c(CRAN = "https://packagemanager.posit.co/cran/latest"))' >> "${R_HOME}/etc/Rprofile.site"

RUN install2.r \
  rsconnect \
  ellmer \
  shinychat \
  bslib \
  dplyr \
  readr \
  purrr \
  glue \
  furrr \
  stringr \
  sass \
  future \
  devtools

WORKDIR /home/dorothy_dAI
COPY data data
COPY chat_bot chat_bot
COPY deploy_chat_bot.R deploy_chat_bot.R
COPY .Renviron .Renviron
CMD Rscript deploy_chat_bot.R