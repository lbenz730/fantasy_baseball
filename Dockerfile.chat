FROM rocker/shiny:4.4.2

RUN install2.r \
  rsconnect \
  ellmer \
  shinychat \
  bslib \
  dplyr \
  readr \
  purrr \
  glue \
  furrr \
  stringr \
  sass \
  future \
  devtools 	

WORKDIR /home/dorothy_dAI
COPY data data
COPY chat_bot chat_bot
COPY deploy_chat_bot.R deploy_chat_bot.R
COPY .Renviron .Renviron
CMD Rscript deploy_chat_bot.R